# Database (local Docker: docker-compose up -d)
DATABASE_URL=postgresql://vindex:vindex@localhost:5432/vindex

# Auth
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Cloudinary — photo storage for inspections
# Cloud name: found in Cloudinary Dashboard > Product Environment > Cloud Name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Upload preset: Settings > Upload > Upload presets. Must be "unsigned" for client-side uploads.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# API key & secret: only needed for server-side operations (not used for unsigned uploads).
# Found in Settings > API Keys.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VIN Decoding (auto.dev — paid, pay-per-request)
AUTO_DEV_API_KEY=your-auto-dev-api-key

# Analytics (optional in dev)
POSTHOG_KEY=
POSTHOG_HOST=
